{
  "name": "tracechain-pharma-dapp",
  "private": true,
  "version": "1.0.0",
  "description": "Hybrid DApp for pharmaceutical supply-chain traceability with blockchain-backed audit trails.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=20.11.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev": "concurrently -n web,api \"npm:dev:web\" \"npm:dev:api\"",
    "dev:web": "npm run dev --workspace @tracechain/web",
    "dev:api": "npm run dev --workspace @tracechain/api",
    "build": "npm run build --workspace @tracechain/shared && npm run build --workspace @tracechain/api && npm run build --workspace @tracechain/web && npm run build --workspace @tracechain/contracts",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "npm run test --workspace @tracechain/web && npm run test --workspace @tracechain/api && npm run test --workspace @tracechain/contracts",
    "prepare": "husky",
    "db:push": "npm run prisma:push --workspace @tracechain/api",
    "db:seed": "npm run prisma:seed --workspace @tracechain/api",
    "contracts:compile": "npm run compile --workspace @tracechain/contracts",
    "contracts:test": "npm run test --workspace @tracechain/contracts",
    "contracts:node": "npm run node --workspace @tracechain/contracts",
    "contracts:deploy:local": "npm run deploy:local --workspace @tracechain/contracts",
    "contracts:deploy:sepolia": "npm run deploy:sepolia --workspace @tracechain/contracts",
    "prisma:generate": "npm run prisma:generate --workspace @tracechain/api",
    "postinstall": "npm run prisma:generate --workspace @tracechain/api"
  },
  "devDependencies": {
    "@eslint/js": "^9.20.0",
    "concurrently": "^9.1.2",
    "eslint": "^9.20.1",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.18",
    "globals": "^16.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.4.3",
    "prettier": "^3.5.3",
    "tsup": "^8.4.0",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.24.1"
  }
}
